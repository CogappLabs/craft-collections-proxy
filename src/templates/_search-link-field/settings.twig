{% import "_includes/forms" as forms %}

{{ forms.textField({
    label: "Index"|t('collections-proxy'),
    instructions: "The search index handle. Leave blank to use the plugin default. Supports environment variables."|t('collections-proxy'),
    id: 'index',
    name: 'index',
    value: field.index ?: defaultIndex,
}) }}

{{ forms.textField({
    label: "Thumbnail field"|t('collections-proxy'),
    instructions: "Optional. Name of the `_source` field that holds a thumbnail URL (e.g. `thumbnail_url`). Leave blank to hide thumbnails in the search UI."|t('collections-proxy'),
    id: 'thumbnailField',
    name: 'thumbnailField',
    value: field.thumbnailField,
}) }}

{{ forms.textField({
    label: "Title field"|t('collections-proxy'),
    instructions: "Optional. Name of the `_source` field to show as each result's title. Leave blank to use the plugin default (`#{defaultTitleField}`)."|t('collections-proxy'),
    id: 'titleField',
    name: 'titleField',
    value: field.titleField,
    placeholder: defaultTitleField,
}) }}
