<div class="search-link-field"
     data-action-url="{{ actionUrl }}"
     data-index="{{ index }}"
     data-field-handle="{{ field.handle }}">

    <input type="hidden" name="{{ field.handle }}[indexHandle]" value="{{ index }}" class="slf-index">
    <input type="hidden" name="{{ field.handle }}[documentId]" value="{{ documentId }}" class="slf-doc-id">
    <input type="hidden" name="{{ field.handle }}[documentTitle]" value="{{ documentTitle }}" class="slf-doc-title">

    {# Selected document display #}
    <div class="slf-selected" style="{% if not documentId %}display:none{% endif %}; margin-bottom: 0.75rem;">
        <div style="display:flex; align-items:flex-start; gap:0.75rem; padding:0.75rem; background:var(--gray-050); border-radius:4px;">
            <div class="slf-selected-thumb" style="flex-shrink:0; width:80px; height:80px; border-radius:4px; overflow:hidden; background:var(--gray-100);{% if not documentId %} display:none{% endif %}">
                <img class="slf-selected-img" src="" alt="" style="width:100%; height:100%; object-fit:cover;" loading="lazy">
            </div>
            <div style="flex-grow:1; min-width:0;">
                <span class="slf-selected-title" style="font-weight:500; display:block;">{{ documentTitle }}</span>
                <span class="light slf-selected-id" style="font-size:0.8em;">#{{ documentId }}</span>
            </div>
            <button type="button" class="btn small slf-clear" style="align-self:center;">Clear</button>
        </div>
    </div>

    {# Search input #}
    <div class="slf-search" style="{% if documentId %}display:none{% endif %}">
        <div style="display:flex; gap:0.5rem; margin-bottom:0.5rem;">
            <div class="flex-grow">
                <input type="text" class="text fullwidth slf-query" placeholder="Search {{ index }}…" autocomplete="off">
            </div>
            <button type="button" class="btn submit slf-go">Search</button>
        </div>
        <div class="slf-results" style="max-height:300px; overflow-y:auto;"></div>
    </div>
</div>

{% js %}
(function () {
    var wrappers = document.querySelectorAll('.search-link-field[data-field-handle="{{ field.handle }}"]');
    var wrapper = wrappers[wrappers.length - 1];
    if (!wrapper || wrapper.dataset.slfInit) return;
    wrapper.dataset.slfInit = '1';

    var actionUrl = wrapper.getAttribute('data-action-url');
    var index = wrapper.getAttribute('data-index');
    var docIdInput = wrapper.querySelector('.slf-doc-id');
    var docTitleInput = wrapper.querySelector('.slf-doc-title');
    var selectedEl = wrapper.querySelector('.slf-selected');
    var selectedTitle = wrapper.querySelector('.slf-selected-title');
    var selectedId = wrapper.querySelector('.slf-selected-id');
    var selectedThumb = wrapper.querySelector('.slf-selected-thumb');
    var selectedImg = wrapper.querySelector('.slf-selected-img');
    var searchEl = wrapper.querySelector('.slf-search');
    var queryInput = wrapper.querySelector('.slf-query');
    var goBtn = wrapper.querySelector('.slf-go');
    var resultsEl = wrapper.querySelector('.slf-results');
    var clearBtn = wrapper.querySelector('.slf-clear');

    function proxyThumb(url) {
        if (!url) return '';
        return url.replace(/https?:\/\/famsf\.emuseum\.com\/apis\/iiif\/image\/v[23]\//, '/_iiif/');
    }

    function selectDoc(id, title, thumbUrl) {
        docIdInput.value = id;
        docTitleInput.value = title;
        selectedTitle.textContent = title;
        selectedId.textContent = '#' + id;
        if (thumbUrl) {
            selectedImg.src = proxyThumb(thumbUrl);
            selectedImg.alt = title;
            selectedThumb.style.display = '';
        } else {
            selectedThumb.style.display = 'none';
        }
        selectedEl.style.display = '';
        searchEl.style.display = 'none';
        resultsEl.innerHTML = '';
        queryInput.value = '';
    }

    // Fetch thumbnail for already-saved document on page load
    if (docIdInput.value) {
        Craft.sendActionRequest('GET', actionUrl, { params: { index: index, q: docIdInput.value, perPage: 5 } })
            .then(function (res) {
                var items = (res.data && res.data.results) || [];
                var docId = docIdInput.value;
                for (var i = 0; i < items.length; i++) {
                    if (String(items[i].id) === docId) {
                        var thumb = (items[i].source || {}).iiif_thumbnail_url || '';
                        if (thumb) {
                            selectedImg.src = proxyThumb(thumb);
                            selectedImg.alt = docTitleInput.value;
                            selectedThumb.style.display = '';
                        } else {
                            selectedThumb.style.display = 'none';
                        }
                        return;
                    }
                }
                // ID not in search results — hide thumb placeholder
                selectedThumb.style.display = 'none';
            })
            .catch(function () { selectedThumb.style.display = 'none'; });
    }

    clearBtn.addEventListener('click', function () {
        docIdInput.value = '';
        docTitleInput.value = '';
        selectedEl.style.display = 'none';
        selectedThumb.style.display = 'none';
        searchEl.style.display = '';
        queryInput.focus();
    });

    function doSearch() {
        var q = queryInput.value.trim();
        if (!q) return;
        goBtn.classList.add('loading');
        resultsEl.innerHTML = '';

        Craft.sendActionRequest('GET', actionUrl, { params: { index: index, q: q, perPage: 8 } })
            .then(function (res) {
                goBtn.classList.remove('loading');
                var items = (res.data && res.data.results) || [];
                if (!items.length) {
                    resultsEl.innerHTML = '<p class="zilch">No results.</p>';
                    return;
                }
                var html = '<ul style="list-style:none; margin:0; padding:0;">';
                for (var i = 0; i < items.length; i++) {
                    var s = items[i].source || {};
                    var title = s.title || s.name || '(untitled)';
                    var id = items[i].id;
                    var thumb = s.iiif_thumbnail_url || '';
                    var proxiedThumb = proxyThumb(thumb);
                    var thumbHtml = proxiedThumb
                        ? '<img src="' + Craft.escapeHtml(proxiedThumb) + '" alt="" style="width:40px; height:40px; object-fit:cover; border-radius:3px; flex-shrink:0;">'
                        : '<div style="width:40px; height:40px; background:var(--gray-100); border-radius:3px; flex-shrink:0;"></div>';
                    html += '<li style="padding:0.4rem 0; border-bottom:1px solid var(--gray-200); cursor:pointer; display:flex; align-items:center; gap:0.5rem;" '
                        + 'data-id="' + Craft.escapeHtml(String(id)) + '" '
                        + 'data-title="' + Craft.escapeHtml(title) + '" '
                        + 'data-thumb="' + Craft.escapeHtml(thumb) + '">'
                        + thumbHtml
                        + '<div style="min-width:0; flex-grow:1;">'
                        + '<span style="font-weight:500;">' + Craft.escapeHtml(title) + '</span> '
                        + '<span class="light" style="font-size:0.8em;">#' + Craft.escapeHtml(String(id)) + '</span>'
                        + '</div>'
                        + '</li>';
                }
                html += '</ul>';
                resultsEl.innerHTML = html;

                resultsEl.querySelectorAll('li').forEach(function (li) {
                    li.addEventListener('click', function () {
                        selectDoc(this.getAttribute('data-id'), this.getAttribute('data-title'), this.getAttribute('data-thumb'));
                    });
                });
            })
            .catch(function () {
                goBtn.classList.remove('loading');
                resultsEl.innerHTML = '<p class="error">Search failed.</p>';
            });
    }

    goBtn.addEventListener('click', doSearch);
    queryInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
    });
})();
{% endjs %}
